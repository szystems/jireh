# ==========================================
# CONFIGURACIÓN PARA DESARROLLO LOCAL
# ==========================================

# Información básica de la aplicación
APP_NAME="Jireh Automotriz"
APP_ENV=local
APP_KEY=base64:xiIpo1QczF5Kb/rviPdZ4H4mAhXCLXjOPZbPligtx0M=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Configuración de logs para desarrollo
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Base de datos - Configuración LOCAL
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dbjirehapp
DB_USERNAME=root
DB_PASSWORD=

# ==========================================
# CONFIGURACIÓN PARA DESARROLLO LOCAL
# ==========================================

# Sesiones - ARCHIVOS para desarrollo local
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_COOKIE=jireh_session
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

# Cache - ARCHIVOS para desarrollo
CACHE_DRIVER=file
CACHE_PREFIX=jireh_cache

# Sistema para desarrollo local
BROADCAST_DRIVER=log
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync

# Configuración de memoria para desarrollo
MEMCACHED_HOST=127.0.0.1
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Email - Configuración para desarrollo (usar mailtrap o similar)
MAIL_MAILER=smtp
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=test@example.com
MAIL_FROM_NAME="${APP_NAME}"

# Servicios externos - Mantener vacíos en desarrollo
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ==========================================
# CONFIGURACIONES PARA DESARROLLO LOCAL
# ==========================================

# NO especificar VIEW_COMPILED_PATH para usar el default
# Esto permitirá que Laravel use storage/framework/views automáticamente
