# ==========================================
# HTACCESS BÁSICO PARA IPAGE - COMPATIBLE
# ==========================================

# Habilitar rewrite engine
RewriteEngine On

# Manejar Authorization Header (importante para Laravel)
RewriteCond %{HTTP:Authorization} .
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# Remover trailing slashes si no es un directorio
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} (.+)/$
RewriteRule ^ %1 [L,R=301]

# Enviar todas las peticiones a index.php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ index.php [L]

# Configuración de seguridad básica
<FilesMatch "\.(env|log)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Configuración de PHP (si el servidor lo permite)
<IfModule mod_php7.c>
    php_value memory_limit 256M
    php_value max_execution_time 300
    php_value upload_max_filesize 64M
    php_value post_max_size 64M
    php_value max_input_vars 3000
    php_flag log_errors on
    php_value error_log /tmp/php_errors.log
</IfModule>
